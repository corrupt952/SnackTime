{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["chrome", "node"]
  },
  "exclude": [
    "node_modules",
    ".output",
    "e2e",
    "**/*.stories.tsx",
    "**/*.stories.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
